From 46670dce02361a318fc66e503d32a0ceb53ec1ea Mon Sep 17 00:00:00 2001
From: Haihua Hu <jared.hu@nxp.com>
Date: Mon, 30 Jun 2025 17:56:50 +0900
Subject: [PATCH] YOCIMX-9095 pipewiresrc: set rank to secondary

Upstream-Status: Pending

currently, pipewiresrc cannot been used as default
video or audio src, so no need primary rank.

Signed-off-by: Haihua Hu <jared.hu@nxp.com>
---
 src/gst/gstpipewire.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/gst/gstpipewire.c b/src/gst/gstpipewire.c
index 5761a099d..15f2ac946 100644
--- a/src/gst/gstpipewire.c
+++ b/src/gst/gstpipewire.c
@@ -26,7 +26,7 @@ plugin_init (GstPlugin *plugin)
 {
   pw_init (NULL, NULL);
 
-  gst_element_register (plugin, "pipewiresrc", GST_RANK_PRIMARY + 1,
+  gst_element_register (plugin, "pipewiresrc", GST_RANK_SECONDARY + 1,
       GST_TYPE_PIPEWIRE_SRC);
   gst_element_register (plugin, "pipewiresink", GST_RANK_NONE,
       GST_TYPE_PIPEWIRE_SINK);
-- 
2.34.1

