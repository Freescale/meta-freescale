From 0c50b2e474a0887aaefb1ae47af2c9b755cd1a12 Mon Sep 17 00:00:00 2001
From: Haihua Hu <jared.hu@nxp.com>
Date: Tue, 8 Jul 2025 17:22:38 +0900
Subject: [PATCH] YOCIMX-9113 rtsp examples: install test-launch and test-uri
 into rootfs

gstreamer community has no plan to install these binary as test tool
https://discourse.gstreamer.org/t/gst-rtsp-server-examples-are-not-installed-by-default/4806

Upstream-Status: Inappropriate [i.MX specific]

Signed-off-by: Haihua Hu <jared.hu@nxp.com>
---
 examples/meson.build | 15 +++++++++++++--
 1 file changed, 13 insertions(+), 2 deletions(-)

diff --git a/examples/meson.build b/examples/meson.build
index 100c3f99f3..5939fb5ff6 100644
--- a/examples/meson.build
+++ b/examples/meson.build
@@ -7,7 +7,6 @@ examples = [
   'test-appsrc2',
   'test-auth',
   'test-auth-digest',
-  'test-launch',
   'test-mp4',
   'test-multicast2',
   'test-multicast',
@@ -22,11 +21,15 @@ examples = [
   'test-record',
   'test-replay-server',
   'test-sdp',
-  'test-uri',
   'test-video',
   'test-video-rtx',
 ]
 
+install_examples = [
+  'test-launch',
+  'test-uri',
+]
+
 foreach example : examples
   executable(example, '@0@.c'.format(example),
     c_args : rtspserver_args,
@@ -35,6 +38,14 @@ foreach example : examples
     install: false)
 endforeach
 
+foreach example : install_examples
+  executable(example, '@0@.c'.format(example),
+    c_args : rtspserver_args,
+    include_directories : rtspserver_incs,
+    dependencies : [gst_dep, gstapp_dep, gstnet_dep, gst_rtsp_server_dep],
+    install: true)
+endforeach
+
 cgroup_dep = dependency('libcgroup', version : '>= 0.26', required : false)
 if cgroup_dep.found()
   executable('test-cgroups', 'test-cgroups.c',
-- 
